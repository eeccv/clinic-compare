generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinics   Clinic[]
  reviews   Review[]
}

enum Role {
  USER
  CLINIC_OWNER
  ADMIN
}

model Clinic {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  city        String
  address     String?
  phone       String?
  whatsapp    String?
  website     String?
  logo        String?
  images      String[]
  verified    Boolean        @default(false)
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  doctors     Doctor[]
  services    ClinicService[]
  reviews     Review[]
  owner       User?          @relation(fields: [ownerId], references: [id])
  ownerId     String?
}

model Doctor {
  id         String  @id @default(cuid())
  name       String
  specialty  String
  experience Int?
  image      String?
  clinic     Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId   String
}

model Service {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  category    String
  description String?
  image       String?
  clinics     ClinicService[]
}

model ClinicService {
  id        String  @id @default(cuid())
  price     Float
  priceMax  Float?
  currency  String  @default("SAR")
  notes     String?
  clinic    Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId  String
  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String

  @@unique([clinicId, serviceId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  author    String
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId  String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  image       String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
